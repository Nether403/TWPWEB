# ============================================================
# The Witness Protocol Portal — Environment Variables
# ============================================================
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.
#
# The Portal is front-of-house only. It owns no auth, intake, or consent
# route — it links OUT to the live Platform (TWP-platform) for all real
# actions. These are PUBLIC URLs only; no secrets belong in this file.
# ============================================================

# -- Platform link-out base URL (lib/platform-links.ts) --
# Origin of the live Platform that the Portal links out to for the real Gate
# intake (/gate), reviewer/MHS packet (/packet, /api/intake), participation &
# consent (/dashboard/consent), and the real Inquisitor (/api/inquisitor).
# NEXT_PUBLIC_ prefix so the value is available in client components
# (Gate simulator, Inquisitor comparator). Defaults to the production origin
# when unset, so the build works without it.
NEXT_PUBLIC_PLATFORM_BASE_URL=https://thewprotocol.online

# -- Portal site origin (lib/sitemap.ts) --
# The Portal's OWN public origin, used to form absolute URLs in the generated
# sitemap (/sitemap.xml). Defaults to the production origin when unset, so the
# build works without it. Set per deployment (e.g. a staging origin) as needed.
NEXT_PUBLIC_SITE_URL=https://thewprotocol.online

# ============================================================
# Form submission layer (SERVER-ONLY secrets) — lib/submissions.ts
# ============================================================
# These power the TWO Portal-owned forms (funder/invoice + contact) ONLY.
# They are SERVER-ONLY: no NEXT_PUBLIC_ prefix, so Next never inlines them into
# client bundles. NEVER expose these to the browser. When unset, the route
# handler returns the 500 "please retry" path rather than leaking errors.

# -- Platform Supabase (persistence) --
# The Platform's Supabase project URL.
SUPABASE_URL=https://your-project.supabase.co
# Server-only, LEAST-PRIVILEGE INSERT-only credential for `portal_submissions`
# (RLS insert-only). Per design, prefer this scoped role over a broad
# service-role key that can read the witness/consent/audit tables.
SUPABASE_SERVICE_ROLE_KEY=your-insert-only-service-key

# -- Resend (notification email, best-effort after a successful persist) --
RESEND_API_KEY=your-resend-api-key
# Where Portal form notifications are delivered, and the verified From address.
PORTAL_NOTIFICATION_EMAIL=foundation@example.org
PORTAL_NOTIFICATION_FROM=portal@thewprotocol.online
